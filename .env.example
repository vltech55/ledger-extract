# ---- LLM ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Active prompt version ----
# Defined in src/extraction/extract/prompts.py.
PROMPT_VERSION=v2

# ---- Database ----
POSTGRES_USER=extract
POSTGRES_PASSWORD=extract
POSTGRES_DB=extract
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://extract:extract@postgres:5432/extract
DATABASE_URL_SYNC=postgresql+psycopg://extract:extract@postgres:5432/extract

# ---- Redis (Celery broker + result backend) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Storage ----
UPLOAD_DIR=/app/data/uploads
SAMPLES_DIR=/app/data/samples
MAX_UPLOAD_MB=20

# ---- Confidence ----
CONFIDENCE_AUTO_APPROVE=0.85
CONFIDENCE_REVIEW_FLOOR=0.0

# ---- HTTP ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000

LOG_LEVEL=INFO
